
class Idcard {
String name;
int idNumber;
String department;

IdCard(String n, int id, String dept) {
name = n;
idNumber = id;
department = dept;
}
void display() {
System.out.println("ID Card Details:");
System.out.println("Name: " + name);
System.out.println("ID Number: " + idNumber);
System.out.println("Department: " + department);
}
}
public class Main (
public static void main(String[] args) {
IdCard student1 = new IdCard("Anan Barua", 101, "CCE");
 student1.display();
}
}

